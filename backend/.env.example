# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  TestGenRAG configuration. Copy to `.env` and edit. Sensible defaults let  ║
# ║  the app run fully offline and free (Ollama + local embeddings).           ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── LLM provider ──────────────────────────────────────────────────────────────
# anthropic | openai | bedrock | nvidia_deepseek | nvidia_moonshot | ollama
LLM_PROVIDER=ollama

# Local, free, offline (default). Requires Ollama running + `ollama pull mistral`.
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# Hosted + free via NVIDIA NIM (good for cloud deploys where Ollama can't run).
# Users can supply their own key via the UI (bring-your-own-key mode), so
# NVIDIA_API_KEY is optional on the server — leave it blank and users enter
# theirs in the app. Get a free key at https://build.nvidia.com
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_MODEL=deepseek-ai/deepseek-v3
# NVIDIA_API_KEY_MOONSHOT=nvapi-...
# NVIDIA_MODEL_MOONSHOT=moonshotai/kimi-k2-instruct

# Paid / enterprise options:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# ── Embeddings provider ───────────────────────────────────────────────────────
# huggingface (free, local, default) | openai
EMBEDDINGS_PROVIDER=huggingface
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── PDF extraction ────────────────────────────────────────────────────────────
# pypdf (default, fast) | pdfplumber (tables/layout) | docling (richest, heavy)
PDF_EXTRACTOR=pypdf

# ── Retrieval ─────────────────────────────────────────────────────────────────
# mmr (diversity) | page_type (boost spec/table pages) | none
RERANK_METHOD=mmr

# ── Vector index ──────────────────────────────────────────────────────────────
FAISS_DIR=faiss_index

# ── Cache (optional) ──────────────────────────────────────────────────────────
# Set a Redis URL to enable shared caching; otherwise in-memory is used.
# REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# ── Database (optional) ───────────────────────────────────────────────────────
# PostgreSQL for approved test cases; defaults to a local SQLite file if unset.
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/testgenrag

# ── Auth (optional, disabled by default) ──────────────────────────────────────
AUTH_ENABLED=false
# AWS Cognito:
# COGNITO_REGION=eu-central-1
# COGNITO_USER_POOL_ID=eu-central-1_xxxxxxxxx
# COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
# Okta / generic OIDC (Okta federates SAML and issues OIDC JWTs):
# OIDC_ISSUER=https://your-org.okta.com/oauth2/default
# OIDC_AUDIENCE=api://default

# ── AWS S3 (optional raw-file storage) ────────────────────────────────────────
AWS_REGION=eu-central-1
S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*
